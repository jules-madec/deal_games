{# templates/base.html.twig #}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}DealGames{% endblock %}</title>
        <link rel="icon" href="{{ asset('favicon.ico') }}">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}

        <style>
            @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Nunito:wght@400;600;700&display=swap');

            * { margin: 0; padding: 0; box-sizing: border-box; }

            body {
                background-color: #0a0a0f;
                color: #e0e0f0;
                font-family: 'Nunito', sans-serif;
                min-height: 100vh;
            }

            .dg-navbar {
                background: rgba(10, 10, 20, 0.95);
                backdrop-filter: blur(12px);
                border-bottom: 1px solid rgba(100, 220, 255, 0.15);
                padding: 0 2rem;
                height: 70px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                position: sticky;
                top: 0;
                z-index: 1000;
            }

            .dg-navbar-brand {
                display: flex;
                align-items: center;
                gap: 12px;
                text-decoration: none;
            }

            .dg-navbar-brand img {
                height: 48px;
                width: auto;
                filter: drop-shadow(0 0 8px rgba(100, 200, 255, 0.4));
            }

            .dg-navbar-brand span {
                font-family: 'Rajdhani', sans-serif;
                font-size: 1.7rem;
                font-weight: 700;
                background: linear-gradient(90deg, #a855f7, #22d3ee);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

            .dg-nav-links {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                list-style: none;
            }

            .dg-nav-links a {
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 8px 18px;
                border-radius: 10px;
                text-decoration: none;
                font-family: 'Rajdhani', sans-serif;
                font-size: 1rem;
                font-weight: 600;
                color: #a0a0c0;
                letter-spacing: 0.5px;
                transition: all 0.2s ease;
            }

            .dg-nav-links a:hover {
                color: #22d3ee;
                background: rgba(34, 211, 238, 0.08);
            }

            .dg-nav-links a.active {
                color: #22d3ee;
                background: rgba(34, 211, 238, 0.12);
                border: 1px solid rgba(34, 211, 238, 0.25);
            }

            @media (max-width: 600px) {
                .dg-navbar { padding: 0 1rem; }
                .dg-nav-links a span.nav-label { display: none; }
            }
        </style>
    </head>
    <body>

        
        <nav class="dg-navbar">
            <a href="{{ path('app_home') }}" class="dg-navbar-brand">
                <img src="{{ asset('images/Logo_de_DealGames_avec_manette_stylisée-removebg-preview 1.png') }}" alt="DealGames logo">
                <span>DealGames</span>
            </a>

            <ul class="dg-nav-links">
                <li>
                    <a href="{{ path('app_home') }}"
                       class="{{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}">
                        <span class="nav-label">Accueil</span>
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_announcement_index') }}"
                       class="{{ app.request.attributes.get('_route') == 'app_announcement_index' ? 'active' : '' }}">
                        <span class="nav-label">Mes publications</span>
                    </a>
                </li>

                {% if is_granted('ROLE_ADMIN') %}
                    <li>
                        <a href="{{ path('app_user_index') }}"
                           class="{{ app.request.attributes.get('_route') == 'app_user_index' ? 'active' : '' }}">
                            <span class="nav-label">Liste User</span>
                        </a>
                    </li>
                {% endif %}

                <li>
                    <a href="{{ path('app_user_profile') }}"
                       class="{{ app.request.attributes.get('_route') == 'app_user_profile' ? 'active' : '' }}">
                        <span class="nav-label">Compte</span>
                    </a>
                </li>
            </ul>
        </nav>

        {% block body %}{% endblock %}

    </body>
</html>