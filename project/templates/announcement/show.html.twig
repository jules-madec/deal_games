{% extends 'base.html.twig' %}

{% block title %}Announcement{% endblock %}

{% block body %}
<style>
    .dg-hero {
        text-align: center;
        padding: 3.5rem 2rem 2.5rem;
        position: relative;
        overflow: hidden;
    }

    .dg-hero::before {
        content: '';
        position: absolute;
        top: -60px;
        left: 50%;
        transform: translateX(-50%);
        width: 600px;
        height: 300px;
        background: radial-gradient(ellipse, rgba(168, 85, 247, 0.12) 0%, transparent 70%);
        pointer-events: none;
    }

    .dg-hero h1 {
        font-family: 'Rajdhani', sans-serif;
        font-size: 2.2rem;
        font-weight: 700;
        background: linear-gradient(90deg, #a855f7, #22d3ee, #a3e635);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 0.5rem;
    }

    .dg-main {
        max-width: 680px;
        margin: 0 auto;
        padding: 0 1.5rem 4rem;
    }

    .dg-profile-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(100, 220, 255, 0.1);
        border-radius: 16px;
        overflow: hidden;
        position: relative;
    }

    .dg-profile-card::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: linear-gradient(180deg, #a855f7, #22d3ee);
        border-radius: 3px 0 0 3px;
    }

    .dg-profile-card table {
        width: 100%;
        border-collapse: collapse;
    }

    .dg-profile-card th {
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #4040a0;
        width: 160px;
        padding: 14px 20px;
        border-bottom: 1px solid rgba(100, 220, 255, 0.06);
        text-align: left;
    }

    .dg-profile-card td {
        color: #a0a0c0;
        font-size: 0.93rem;
        padding: 14px 20px;
        border-bottom: 1px solid rgba(100, 220, 255, 0.06);
        word-break: break-word;
    }

    .dg-profile-card tbody tr:last-child th,
    .dg-profile-card tbody tr:last-child td {
        border-bottom: none;
    }

    .dg-form-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 1.5rem;
        flex-wrap: wrap;
    }

    .dg-form-actions a {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 22px;
        border-radius: 10px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        background: linear-gradient(135deg, rgba(168, 85, 247, 0.2), rgba(34, 211, 238, 0.2));
        color: #22d3ee;
        border: 1px solid rgba(34, 211, 238, 0.25);
    }

    .dg-form-actions a:hover {
        background: linear-gradient(135deg, rgba(168, 85, 247, 0.35), rgba(34, 211, 238, 0.35));
        border-color: rgba(34, 211, 238, 0.5);
        color: #fff;
    }

    .dg-btn-danger {
        display: inline-flex;
        background: rgba(248, 113, 113, 0.08);
        color: #f87171;
        border: 1px solid rgba(248, 113, 113, 0.2);
        border-radius: 10px;
        padding: 2px 4px;
        transition: all 0.2s ease;
    }

    .dg-btn-danger:hover {
        background: rgba(248, 113, 113, 0.18);
        border-color: rgba(248, 113, 113, 0.4);
    }
</style>

<div class="dg-hero">
    <h1>Announcement</h1>
</div>

<main class="dg-main">

    <div class="dg-profile-card">
        <table class="table">
            <tbody>
                <tr>
                    <th>Title</th>
                    <td>{{ announcement.tittitle }}</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>{{ announcement.description }}</td>
                </tr>
                <tr>
                    <th>PublicationDate</th>
                    <td>{{ announcement.publicationDate ? announcement.publicationDate|date('Y-m-d H:i:s') : '' }}</td>
                </tr>
                <tr>
                    <th>Contact</th>
                    <td>{{announcement.user.email}}</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="dg-form-actions">
        {% if announcement.user == app.user or is_granted ('ROLE_ADMIN') %}
            <a href="{{ path('app_announcement_edit', {'id': announcement.id}) }}">edit</a>
        {% endif %}

        {% if announcement.user == app.user or is_granted ('ROLE_ADMIN') %}
            <span class="dg-btn-danger">{{ include('announcement/_delete_form.html.twig') }}</span>
        {% endif %}
    </div>

</main>
{% endblock %}