{% extends 'base.html.twig' %}

{% block title %}Announcement index{% endblock %}

{% block body %}
    <h1>Announcement index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titre</th>
                <th>Description</th>
                <th>Date de publication</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for announcement in announcements %}
            <tr>
                <td>{{ announcement.id }}</td>
                <td>{{ announcement.tittitle }}</td>
                <td>{{ announcement.description }}</td>
                <td>{{ announcement.publicationDate ? announcement.publicationDate|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    {% if announcement.isPublished %}
                        <span > Publié</span>
                    {% else %}
                        <span > Brouillon</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_announcement_show', {'id': announcement.id}) }}">show</a>
                    <a href="{{ path('app_announcement_edit', {'id': announcement.id}) }}">edit</a>
                    <form method="post" action="{{ path('app_announcement_publish', {'id': announcement.id}) }}" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('publish' ~ announcement.id) }}">
                        <button type="submit">
                            {{ announcement.isPublished ? 'Dépublier' : 'Publier' }}
                        </button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_announcement_new') }}">Create new</a>
    <a href="/">home</a>
{% endblock %}